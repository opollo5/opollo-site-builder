# ─────────────────────────────────────────────────────────────
# Opollo Site Builder — Composer workstream env vars
# ─────────────────────────────────────────────────────────────
# Copy to .env.local for development, or set in Vercel for staging/prod.

# ─── bundle.social (publishing layer) ───────────────────────
# Get from https://bundle.social dashboard
BUNDLE_SOCIAL_API=
# HMAC-SHA256 signing secret for incoming webhooks
BUNDLE_SOCIAL_WEBHOOK_SECRET=

# ─── Ideogram (image generation) ────────────────────────────
IDEOGRAM_API_KEY=

# ─── Upstash Redis (hot analytics cache) ────────────────────
# Hot cache layer. Postgres social_post_analytics_cache is the
# cold-storage fallback if Redis is unavailable.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── SendGrid (approval emails + service health alerts) ─────
# SENDGRID_FROM_EMAIL must be a verified sender in SendGrid.
# Requires SendGrid Domain Authentication for opollo.com.
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@opollo.com

# ─── Anthropic (composer AI assistant + CAP) ────────────────
ANTHROPIC_API_KEY=

# ─── GIPHY (GIF picker in composer) ─────────────────────────
# Free tier from https://developers.giphy.com
GIPHY_API_KEY=

# ─── Vercel Cron auth ───────────────────────────────────────
# Required. Vercel auto-injects this in Authorization header when
# invoking cron endpoints. Generate via: openssl rand -hex 32
# Without this, your cron routes are publicly accessible.
CRON_SECRET=

# ─── Service health monitoring (optional secondary channel) ─
# Slack webhook for critical service-health events. Strongly
# recommended — failsafe channel when SendGrid itself is the
# failing service. If unset, system runs SendGrid-only.
SLACK_WEBHOOK_URL_OPS=

# Admin recipients are discovered at runtime by querying
# company_users WHERE role = 'platform_admin'. No env var needed.

# ─── Feature flags ──────────────────────────────────────────
NEXT_PUBLIC_FEATURE_COMPOSER_V2="true"
FEATURE_UNIFIED_SHELL=false

# ─── Site config ────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL="https://app.opollo.com"

# ─── Supabase (already in Opollo stack) ─────────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=

# ─── Optional: Sentry (already in Opollo stack) ─────────────
# SENTRY_DSN=
# SENTRY_AUTH_TOKEN=
