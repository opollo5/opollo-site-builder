# Catch every .env.* variant so a stray Vercel env dump
# (e.g. `vercel env pull .env.bundlesocial-test`) cannot be
# accidentally committed via `git add -A`. The two specific
# patterns above remain for clarity. Allow .env.example +
# .env.local.example explicitly with !-prefixed exceptions if
# new template names are added.
.env.*
!.env.example
!.env.local.example

.DS_Store
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

.vercel
next-env.d.ts
*.tsbuildinfo

# Output of scripts/bulk-upload-cloudflare-images.py — operational
# upload logs (filenames + cloudflare_ids + per-row status). Resumable
# state, not source.
scripts/output/

# Operator-local Claude Code config + ephemeral state. Per-developer;
# not shared. `.claude/skills/` IS tracked (project-wide playbooks).
.claude/settings.local.json
.claude/settings.json.txt
.claude/worktrees/

