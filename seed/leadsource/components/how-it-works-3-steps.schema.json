{
  "category": "process",
  "variant": "default",
  "content_schema": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "required": ["section_header", "code_snippet", "steps"],
    "additionalProperties": false,
    "properties": {
      "section_header": {
        "type": "object",
        "required": ["eyebrow", "heading"],
        "additionalProperties": false,
        "properties": {
          "eyebrow": { "type": "string", "minLength": 1, "maxLength": 40 },
          "heading": { "type": "string", "minLength": 1, "maxLength": 240 },
          "sub": { "type": "string", "maxLength": 400 }
        }
      },
      "code_snippet": {
        "type": "object",
        "required": ["copy_label", "tokens"],
        "additionalProperties": false,
        "properties": {
          "copy_label": {
            "type": "string",
            "minLength": 1,
            "maxLength": 16,
            "description": "Button label for the copy-to-clipboard affordance (e.g. 'Copy')."
          },
          "tokens": {
            "type": "array",
            "minItems": 1,
            "maxItems": 64,
            "items": {
              "type": "object",
              "required": ["kind", "text"],
              "additionalProperties": false,
              "properties": {
                "kind": {
                  "type": "string",
                  "enum": ["tag", "attr", "str", "plain"],
                  "description": "Syntax-highlight class: tag (pink), attr (blue), str (green), plain (default white)."
                },
                "text": { "type": "string", "minLength": 1, "maxLength": 240 }
              }
            },
            "description": "Tokenised code snippet. Each token renders in the colour bucket identified by its kind. Use 'plain' for whitespace, dots, and uncoloured punctuation."
          }
        }
      },
      "steps": {
        "type": "array",
        "minItems": 3,
        "maxItems": 3,
        "items": {
          "type": "object",
          "required": ["number", "heading", "body"],
          "additionalProperties": false,
          "properties": {
            "number": { "type": "string", "minLength": 1, "maxLength": 4 },
            "heading": { "type": "string", "minLength": 1, "maxLength": 80 },
            "body": { "type": "string", "minLength": 1, "maxLength": 400 }
          }
        }
      }
    }
  },
  "image_slots": null,
  "usage_notes": "Process section with a syntax-highlighted code snippet above three step cards. Section header is centered. The tokenised code_snippet format lets Claude generate colour-correct snippets on other pages without hand-writing span markup.",
  "preview_html": null
}
